# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mediconnect_dev?schema=public"

# ─── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET_MIN_64_CHARS

# ─── Encryption ───────────────────────────────────────────────
# Used for encrypting sensitive DB fields (medical records)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_STRING

# ─── File Storage ─────────────────────────────────────────────
# AWS S3 for production. Use local storage in development.
STORAGE_PROVIDER=local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=mediconnect-records
AWS_S3_BUCKET_REGION=us-east-1
LOCAL_STORAGE_PATH=./uploads

# ─── Email ────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=MediConnect
EMAIL_FROM_ADDRESS=no-reply@mediconnect.com

# ─── Payment — Paystack ───────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_WEBHOOK_SECRET=REPLACE_WITH_PAYSTACK_WEBHOOK_SECRET

# ─── WebRTC / TURN Server ─────────────────────────────────────
# Metered.ca free TURN server for development
TURN_SERVER_URL=turn:your-turn-server.metered.ca:80
TURN_SERVER_USERNAME=your-turn-username
TURN_SERVER_CREDENTIAL=your-turn-credential

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=./logs
